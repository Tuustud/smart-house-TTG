# This file serves as a template for environment variables. It includes example variables that should be set in the actual .env file for configuration.

# Database configuration
DATABASE_URL=sqlite:///smart_house.db

# Flask configuration
FLASK_ENV=development
FLASK_APP=src/backend/app.py
SECRET_KEY=your_secret_key_here

# Sensor configuration
SENSOR_API_KEY=your_sensor_api_key_here
SENSOR_UPDATE_INTERVAL=60  # in seconds

# Other configurations
DEBUG=True
LOG_LEVEL=info